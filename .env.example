# ─── Auth Methods ─────────────────────────────────────────────────────────────
# Comma-separated list. Options: password, google
# Examples:
#   AUTH_METHODS=password            → only username/password (default)
#   AUTH_METHODS=google              → only Google OAuth
#   AUTH_METHODS=password,google     → both methods available

AUTH_METHODS=password

# Allow new users to self-register via the Register tab (true/false)
ALLOW_REGISTRATION=true

# ─── Admin Account (read from env — never hardcoded) ──────────────────────────
# Change these before running in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123
ADMIN_EMAIL=admin@interviews-tracker.local

# ─── Google OAuth (only needed if AUTH_METHODS includes "google") ─────────────
# 1. Go to https://console.cloud.google.com/
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Authorized redirect URI: http://localhost:8000/auth/google/callback
# 4. Paste credentials below and add "google" to AUTH_METHODS

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── App Settings ─────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-in-production

# Base URL — change to your public URL for deployment
BASE_URL=http://localhost:8000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/interviews.db

# For PostgreSQL (Railway/Render):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Token Expiry ─────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_DAYS=7
